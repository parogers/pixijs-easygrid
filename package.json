{
    "name": "@parogers/pixijs-easygrid",
    "version": "0.0.1",
    "description": "A \"good enough\" grid sprite for PixiJS",
    "homepage": "https://github.com/parogers/pixijs-easygrid",
    "main": "dist/pixijs-easygrid.umd.js",
    "module": "dist/pixijs-easygrid.mjs",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "vite build -c vite.config-lib.js",
        "build-watch": "vite build -c vite.config-lib.js --watch",
        "dev": "vite --open /examples/index.html",
        "dev-example-tiles": "./scripts/watch_sample_tiles.sh",
        "lint": "tsc --project ./tsconfig.json --noEmit",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "license": "GPL-3.0",
    "peerDependencies": {
        "pixi.js": "^8.16.0"
    },
    "devDependencies": {
        "@vitest/browser-playwright": "^4.1.2",
        "browser-sync": "^3.0.3",
        "esbuild": "^0.25.6",
        "typescript": "^5.6.3",
        "unplugin-dts": "^1.0.0-beta.6",
        "vite": "^6.4.1",
        "vite-plugin-restart": "^2.0.0",
        "vitest": "^4.1.2"
    },
    "exports": {
        ".": {
            "import": "./dist/pixijs-easygrid.mjs",
            "require": "dist/pixijs-easygrid.umd.js"
        }
    }
}
